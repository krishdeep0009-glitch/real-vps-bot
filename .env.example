# ---------------- Discord ----------------
DISCORD_TOKEN=your_discord_bot_token_here
COMMAND_PREFIX=.
# Role IDs (comma separated) allowed to run admin/deploy commands. Leave empty to allow everyone.
ADMIN_ROLE_IDS=
# Channel where deploy logs are posted (optional)
LOG_CHANNEL_ID=

# ---------------- Proxmox VE -------------
# Your Proxmox host, e.g. https://pve.yourdomain.com:8006
PVE_HOST=https://your-proxmox-host:8006
PVE_USER=root@pam
PVE_TOKEN_NAME=blined-bot
PVE_TOKEN_VALUE=your-api-token-value
PVE_VERIFY_SSL=false

# Node in your Proxmox cluster to deploy VMs on
PVE_NODE=pve1

# VMID of the cloud-init ready template to clone (Ubuntu/Debian cloud image imported as template)
# Used as the fallback/default template if a requested OS isn't in PVE_OS_TEMPLATES below.
PVE_TEMPLATE_ID=9000

# Map of OS keyword -> template VMID. Prepare one cloud-init template per OS
# (see README "Requirements" section for the qm import steps), then list them
# here as comma-separated key=value pairs.
# Keys are what users type in .create, e.g. ubuntu20 ubuntu22 ubuntu24 debian12
PVE_OS_TEMPLATES=ubuntu20=9020,ubuntu22=9022,ubuntu24=9024,debian11=9011,debian12=9012

# Default CPU type passed to Proxmox (qm cpu type), used unless the user
# supplies a custom cpu name in .create. "host" passes through the host's
# real CPU flags (best performance); "kvm64" is the safest for live-migration.
PVE_DEFAULT_CPU_TYPE=host

# Storage pool to use for disks
PVE_STORAGE=local-lvm

# Network bridge to attach VMs to
PVE_BRIDGE=vmbr0

# Range of VMIDs the bot is allowed to allocate new VMs into
VMID_RANGE_START=10000
VMID_RANGE_END=19999

# ---------------- Branding ---------------
HOSTING_NAME=Blined Cloud
